  <style>
    .page-hero{
      position: relative;
      padding: 72px 0 46px;
      overflow: clip;
    }

    .page-hero__bg{
      position: absolute;
      inset: 0;
      pointer-events: none;
      background:
        radial-gradient(circle at 14% 10%, rgba(198,165,106,.13), transparent 24%),
        radial-gradient(circle at 86% 8%, rgba(127,149,201,.11), transparent 22%);
    }

    .page-hero__inner{
      position: relative;
      display: grid;
      gap: 18px;
      max-width: 960px;
    }

    .page-hero__title{
      font-family: "Cormorant Garamond", Georgia, serif;
      font-size: clamp(3rem, 7vw, 5rem);
      line-height: 1.03;
      letter-spacing: -.03em;
      color: var(--text);
    }

    .page-hero__text{
      max-width: 760px;
      font-size: 1.04rem;
      color: #cbd2dd;
    }

    .breadcrumbs{
      display: inline-flex;
      flex-wrap: wrap;
      gap: 10px;
      color: var(--muted-2);
      font-size: .9rem;
    }

    .breadcrumbs a:hover{
      color: var(--brand-2);
    }

    .contact-grid{
      display: grid;
      gap: 22px;
    }

    .form-card,
    .contact-card,
    .service-select-card,
    .faq-card,
    .note-card{
      border: 1px solid var(--line);
      border-radius: 26px;
      background:
        linear-gradient(180deg, rgba(255,255,255,.04), rgba(255,255,255,.02)),
        var(--bg-elev);
      box-shadow: var(--shadow-md);
    }

    .form-card,
    .contact-card,
    .service-select-card,
    .faq-card,
    .note-card{
      padding: 24px;
    }

    .card-title{
      color: var(--text);
      font-size: 1.18rem;
      margin-bottom: 10px;
    }

    .card-text{
      color: var(--muted);
      font-size: .97rem;
      margin-bottom: 18px;
    }

    .project-types{
      display: grid;
      gap: 12px;
    }

    .project-type{
      display: flex;
      align-items: start;
      gap: 12px;
      padding: 14px;
      border: 1px solid var(--line);
      border-radius: 18px;
      background: rgba(255,255,255,.03);
    }

    .project-type__dot{
      width: 12px;
      height: 12px;
      margin-top: .35rem;
      border-radius: 50%;
      background: linear-gradient(135deg, var(--brand), var(--brand-2));
      box-shadow: 0 0 0 6px rgba(198,165,106,.08);
      flex: 0 0 auto;
    }

    .project-type strong{
      display: block;
      color: var(--text);
      font-size: .96rem;
      margin-bottom: 4px;
    }

    .project-type span{
      color: var(--muted);
      font-size: .92rem;
      line-height: 1.5;
    }

    .contact-form{
      display: grid;
      gap: 16px;
    }

    .form-row{
      display: grid;
      gap: 16px;
    }

    .field{
      display: grid;
      gap: 8px;
    }

    .field label{
      color: #e5eaf3;
      font-size: .92rem;
      font-weight: 700;
    }

    .field input,
    .field select,
    .field textarea{
      width: 100%;
      min-height: 54px;
      padding: 0 16px;
      border: 1px solid var(--line);
      border-radius: 18px;
      background: rgba(255,255,255,.035);
      color: var(--text);
      transition:
        border-color var(--dur) var(--ease),
        background var(--dur) var(--ease),
        box-shadow var(--dur) var(--ease);
    }

    .field textarea{
      min-height: 170px;
      padding-top: 16px;
      resize: vertical;
    }

    .field input::placeholder,
    .field textarea::placeholder{
      color: #8b94a3;
    }

    .field input:focus,
    .field select:focus,
    .field textarea:focus{
      border-color: rgba(198,165,106,.35);
      background: rgba(255,255,255,.05);
      box-shadow: 0 0 0 4px rgba(198,165,106,.08);
      outline: none;
    }

    .checkbox-grid{
      display: grid;
      gap: 10px;
    }

    .check-option{
      display: flex;
      align-items: start;
      gap: 12px;
      padding: 12px 14px;
      border: 1px solid var(--line);
      border-radius: 16px;
      background: rgba(255,255,255,.03);
    }

    .check-option input{
      margin-top: .2rem;
      accent-color: var(--brand);
    }

    .check-option span{
      color: #d4dae3;
      font-size: .94rem;
    }

    .form-actions{
      display: flex;
      flex-wrap: wrap;
      gap: 12px;
      padding-top: 4px;
    }

    .contact-list,
    .faq-list,
    .note-list{
      display: grid;
      gap: 12px;
    }

    .contact-item,
    .faq-item,
    .note-list li{
      position: relative;
      padding-left: 22px;
      color: #d5dbe5;
    }

    .contact-item::before,
    .faq-item::before,
    .note-list li::before{
      content: "";
      position: absolute;
      left: 0;
      top: .62em;
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: linear-gradient(135deg, var(--brand), var(--brand-2));
      box-shadow: 0 0 0 5px rgba(198,165,106,.09);
    }

    .contact-links{
      display: grid;
      gap: 12px;
      margin-top: 18px;
    }

    .contact-links a{
      display: flex;
      align-items: center;
      justify-content: space-between;
      min-height: 52px;
      padding: 0 16px;
      border: 1px solid var(--line);
      border-radius: 18px;
      background: rgba(255,255,255,.03);
      color: var(--text);
      font-weight: 700;
      transition: background var(--dur) var(--ease), border-color var(--dur) var(--ease), transform var(--dur) var(--ease);
    }

    .contact-links a:hover{
      background: rgba(255,255,255,.05);
      border-color: rgba(198,165,106,.24);
      transform: translateY(-2px);
    }

    .mini-note{
      margin-top: 16px;
      color: var(--muted-2);
      font-size: .9rem;
    }

    .support-grid{
      display: grid;
      gap: 20px;
    }

    @media (min-width: 900px){
      .contact-grid{
        grid-template-columns: 1.12fr .88fr;
        align-items: start;
      }

      .form-row{
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }

      .support-grid{
        grid-template-columns: repeat(3, minmax(0, 1fr));
      }
    }
  </style>

