      <section class="section">
        <div class="container contact-grid">
          <article class="form-card">
            <h2 class="card-title">Project Inquiry Form</h2>
            <p class="card-text">
              Share what you need and I’ll use this information to understand the direction,
              goals, and level of support your business needs.
            </p>

            <form class="contact-form" action="#" method="post">
              <div class="form-row">
                <div class="field">
                  <label for="name">Full Name</label>
                  <input id="name" name="name" type="text" placeholder="Your name" required />
                </div>

                <div class="field">
                  <label for="business">Business Name</label>
                  <input id="business" name="business" type="text" placeholder="Your business name" />
                </div>
              </div>

              <div class="form-row">
                <div class="field">
                  <label for="email">Email Address</label>
                  <input id="email" name="email" type="email" placeholder="you@example.com" required />
                </div>

                <div class="field">
                  <label for="phone">Phone Number</label>
                  <input id="phone" name="phone" type="tel" placeholder="(000) 000-0000" />
                </div>
              </div>

              <div class="form-row">
                <div class="field">
                  <label for="industry">Business Type</label>
                  <select id="industry" name="industry">
                    <option value="">Select one</option>
                    <option>Barbershop / Salon</option>
                    <option>Retail Store</option>
                    <option>Restaurant / Hospitality</option>
                    <option>Corporate / Engineering</option>
                    <option>Service Business</option>
                    <option>Other</option>
                  </select>
                </div>

                <div class="field">
                  <label for="timeline">Desired Timeline</label>
                  <select id="timeline" name="timeline">
                    <option value="">Select one</option>
                    <option>As soon as possible</option>
                    <option>Within 2–4 weeks</option>
                    <option>Within 1–2 months</option>
                    <option>Flexible / planning stage</option>
                  </select>
                </div>
              </div>

              <div class="field">
                <label>Services Needed</label>
                <div class="checkbox-grid">
                  <label class="check-option">
                    <input type="checkbox" name="services" value="web-design" />
                    <span>Web Design & Development</span>
                  </label>

                  <label class="check-option">
                    <input type="checkbox" name="services" value="storefront-media" />
                    <span>Storefront Media & Signage Direction</span>
                  </label>

                  <label class="check-option">
                    <input type="checkbox" name="services" value="branding" />
                    <span>Brand Presentation Systems</span>
                  </label>

                  <label class="check-option">
                    <input type="checkbox" name="services" value="support" />
                    <span>Ongoing Updates & Support</span>
                  </label>
                </div>
              </div>

              <div class="field">
                <label for="message">Project Details</label>
                <textarea
                  id="message"
                  name="message"
                  placeholder="Tell me about your business, what you need, what you want to improve, and the type of look or experience you want customers to have."
